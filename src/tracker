import json
import os
from datetime import datetime
from rich.console import Console
from rich.table import Table
from rich.prompt import Prompt, Confirm

console = Console()
DB_FILE = "airdrops.json"

def load_data():
    if not os.path.exists(DB_FILE):
        default_data = [
            {"name": "Grass Network", "type": "DePIN Node", "status": "Mainnet Phase", "daily_check": True},
            {"name": "Tea Protocol", "type": "Web3 Dev Platform", "status": "Testnet Incentivized", "daily_check": False},
            {"name": "Interlink Network", "type": "Data Protocol", "status": "Early Alpha", "daily_check": True},
            {"name": "Billions Network (OpenClaw)", "type": "Airdrop Automation", "status": "Configuring Task", "daily_check": True}
        ]
        with open(DB_FILE, "w") as f:
            json.dump(default_data, f, indent=4)
        return default_data
    with open(DB_FILE, "r") as f:
        return json.load(f)

def save_data(data):
    with open(DB_FILE, "w") as f:
        json.dump(data, f, indent=4)

def display_dashboard():
    airdrops = load_data()
    console.print("\n[bold cyan]🚀 CRYPTO AIRDROP & WEB3 TASK TRACKER CLI[/bold cyan]", justify="center")
    console.print(f"📅 System Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n", justify="center")
    
    if not airdrops:
        console.print("[yellow]No active airdrops tracked yet. Try adding one![/yellow]\n")
        return

    table = Table(title="Active Networks & Tasks", title_style="bold magenta")
    table.add_column("No", justify="center", style="dim")
    table.add_column("Network Name", style="bold white")
    table.add_column("Category/Type", style="yellow")
    table.add_column("Status", justify="center")
    table.add_column("Daily Action?", justify="center")

    for idx, item in enumerate(airdrops, 1):
        status_color = "green" if "Mainnet" in item["status"].line else "cyan"
        action_str = "[green]YES (Check-in)[/green]" if item["daily_check"] else "[dim white]No[/dim white]"
        
        table.add_row(str(idx), item["name"], item["type"], f"[{status_color}]{item['status']}[/{status_color}]", action_str)

    console.print(table)

def add_airdrop():
    console.print("\n[bold green]➕ Add New Airdrop Task[/bold green]")
    name = Prompt.ask("Enter Network/Project Name")
    project_type = Prompt.ask("Enter Category (e.g., DePIN, Testnet, Node, Task)")
    status = Prompt.ask("Enter Current Status", default="Testnet")
    daily = Confirm.ask("Does it require daily interaction/check-in?")
    
    airdrops = load_data()
    airdrops.append({
        "name": name,
        "type": project_type,
        "status": status,
        "daily_check": daily
    })
    save_data(airdrops)
    console.print(f"[bold green]✓[/bold green] successfully added [bold white]{name}[/bold white] to tracker!\n")

def delete_airdrop():
    airdrops = load_data()
    if not airdrops:
        console.print("[yellow]Nothing to delete.[/yellow]\n")
        return
        
    display_dashboard()
    try:
        choice = int(Prompt.ask("\nEnter the [bold red]No[/bold red] of the airdrop you want to remove"))
        if 1 <= choice <= len(airdrops):
            removed = airdrops.pop(choice - 1)
            save_data(airdrops)
            console.print(f"[bold red]✓[/bold red] Removed [bold white]{removed['name']}[/bold white] successfully.\n")
        else:
            console.print("[bold red]Invalid number![/bold red]\n")
    except ValueError:
        console.print("[bold red]Please enter a valid number.[/bold red]\n")

def main_menu():
    while True:
        display_dashboard()
        console.print("[bold white][1][/bold white] 🎯 Add New Airdrop")
        console.print("[bold white][2][/bold white] ❌ Delete Airdrop")
        console.print("[bold white][3][/bold white] 🚪 Exit Tracker")
        
        choice = Prompt.ask("\nChoose option", choices=["1", "2", "3"], default="3")
        
        if choice == "1":
            add_airdrop()
        elif choice == "2":
            delete_airdrop()
        elif choice == "3":
            console.print("[bold yellow]Goodbye! Keep hunting airdrops! 🚀[/bold yellow]\n")
            break

def __main__():
    pass

if __name__ == "__main__":
    main_menu()

